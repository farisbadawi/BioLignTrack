{
  "expo": {
    "name": "BioLign Progress - Orthodontic Tracker",
    "slug": "biolign-progress-orthodontic-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/biolign-logo-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.biolign-progress-orthodontic-tracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.biolign-progress-orthodontic-tracker"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BioLign Progress to access your photos to track your smile transformation.",
          "cameraPermission": "Allow BioLign Progress to use your camera to take progress photos of your teeth."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}